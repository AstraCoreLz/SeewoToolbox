<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2D2D2D" />
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#3D3D3D" />
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="HeaderForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SubtextForegroundBrush" Color="#999999" />
</ResourceDictionary>
